{
  "manifest_version": 3,
  "name": "reviewzhealth",
  "version": "1.0.0",
  "description": "Automatically capture reviews from delivery platforms into reviewzhealth.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://merchants.ubereats.com/*",
    "https://merchant-portal.doordash.com/*",
    "https://restaurant.grubhub.com/*",
    "https://biz.yelp.com/*",
    "https://www.tripadvisor.com/*",
    "https://restaurant.opentable.com/*",
    "https://reviewzhealth.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://merchants.ubereats.com/*"],
      "js": ["content-ubereats.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://merchant-portal.doordash.com/*"],
      "js": ["content-doordash.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://restaurant.grubhub.com/*"],
      "js": ["content-grubhub.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://biz.yelp.com/*"],
      "js": ["content-yelp.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.tripadvisor.com/*"],
      "js": ["content-tripadvisor.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://restaurant.opentable.com/*"],
      "js": ["content-opentable.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://reviewzhealth.com/*"],
      "js": ["content-token.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "reviewzhealth"
  }
}